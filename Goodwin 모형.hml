"2"><PICTURE Reverse="false"><SHAPEOBJECT InstId="2092452186" Lock="false" NumberingType="Figure" TextFlow="BothSides" TextWrap="Square" ZOrder="19"><SIZE Height="22303" HeightRelTo="Absolute" Protect="false" Width="30862" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="true" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="14333" HorzRelTo="Paper" TreatAsChar="false" VertAlign="Top" VertOffset="42454" VertRelTo="Paper"/><OUTSIDEMARGIN Bottom="0" Left="0" Right="0" Top="0"/><SHAPECOMMENT>그림입니다.
