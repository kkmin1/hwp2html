" AllowOverlap="true" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="23436" HorzRelTo="Paper" TreatAsChar="true" VertAlign="Top" VertOffset="23128" VertRelTo="Paper"/><OUTSIDEMARGIN Bottom="0" Left="0" Right="0" Top="0"/><SHAPECOMMENT>그림입니다.
