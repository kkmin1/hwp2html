="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>한편, </CHAR><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303633" Lock="false" NumberingType="Equation" ZOrder="1057"><SIZE Height="1000" HeightRelTo="Absolute" Protect="false" Width="8320" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>V(y+ TRIANGLE y,`t+ TRIANGLE t)</SCRIPT></EQUATION><CHAR>를 y, t 에서 테일러전개를 하면</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="66" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303634" Lock="false" NumberingType="Equation" ZOrder="1058"><SIZE Height="2250" HeightRelTo="Absolute" Protect="false" Width="21795" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>V(y+ TRIANGLE y,`t+ TRIANGLE t) CONG V(y`,`t)+ {Partial V} over {Partial y}  TRIANGLE y+ {Partial V} over {Partial t}  TRIANGLE t</SCRIPT></EQUATION><CHAR> ..............②</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>②를 ①에 대입하면</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="66" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303636" Lock="false" NumberingType="Equation" ZOrder="1059"><SIZE Height="2250" HeightRelTo="Absolute" Protect="false" Width="19948" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>0`=`  max  _{u(t)`} left{f(y,`u) TRIANGLE t`+` {Partial V} over {Partial y}  TRIANGLE y+ {Partial V} over {Partial t}  TRIANGLE right}</SCRIPT></EQUATION><CHAR/></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>양변을 </CHAR><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303637" Lock="false" NumberingType="Equation" ZOrder="1061"><SIZE Height="975" HeightRelTo="Absolute" Protect="false" Width="1425" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>TRIANGLE t</SCRIPT></EQUATION><CHAR>로 나누면</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="66" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303638" Lock="false" NumberingType="Equation" ZOrder="1060"><SIZE Height="2250" HeightRelTo="Absolute" Protect="false" Width="17833" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>0`=`  max  _{u(t)`} left{f(y,`u)`+` {Partial V} over {Partial y} {TRIANGLE y} over {TRIANGLE t} + {Partial V} over {Partial t} right}</SCRIPT></EQUATION><CHAR/></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1438758587" Lock="false" NumberingType="Equation" ZOrder="2638"><SIZE Height="975" HeightRelTo="Absolute" Protect="false" Width="3000" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>TRIANGLE t -&gt; 0</SCRIPT></EQUATION><CHAR> 이면</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="66" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303642" Lock="false" NumberingType="Equation" ZOrder="1066"><SIZE Height="2275" HeightRelTo="Absolute" Protect="false" Width="20853" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>- {Partial V(y,`t)} over {Partial t} `=`max  _{u(t)`}left{[f(y,`u)`+` {Partial V} over {Partial y} g(y,`u)right}</SCRIPT></EQUATION><CHAR>, (∵ </CHAR><EQUATION BaseLine="62" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303639" Lock="false" NumberingType="Equation" ZOrder="1065"><SIZE Height="2400" HeightRelTo="Absolute" Protect="false" Width="11655" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>lim _{TRIANGLE t -&gt; 0} {{TRIANGLE y} over {TRIANGLE t} =y prime (t)=g(y,`u)}</SCRIPT></EQUATION><CHAR>)</CHAR><FOOTNOTE><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="11"><TEXT CharShape="11"><AUTONUM Number="83" NumberType="Footnote"><AUTONUMFORMAT SuffixChar=")" Superscript="false" Type="Digit"/></AUTONUM><CHAR> </CHAR><EQUATION BaseLine="65" BaseUnit="800" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1437072448" Lock="false" NumberingType="Equation" ZOrder="2580"><SIZE Height="1890" HeightRelTo="Absolute" Protect="false" Width="1375" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>{Partial V} over {Partial t}</SCRIPT></EQUATION><CHAR>는 u와 관계없으므로 max 연산자 밖으로 나와도 된다.</CHAR></TEXT></P></PARALIST></FOOTNOTE><CHAR/></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>이는 시간이 연속일 때의</CHAR></TEXT><TEXT CharShape="19"><CHAR> Bellman 방정식</CHAR></TEXT><TEXT CharShape="8"><CHAR>이다. </CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>이를 특별히 </CHAR></TEXT><TEXT CharShape="19"><CHAR>Hamilton-Jacobi-Bellman(HJB) 방정식</CHAR></TEXT><TEXT CharShape="8"><CHAR>이라 한다.</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="66" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1437072543" Lock="false" NumberingType="Equation" ZOrder="2610"><SIZE Height="2275" HeightRelTo="Absolute" Protect="false" Width="20853" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>- {Partial V(y,`t)} over {Partial t} `=`max  _{u(t)`}left{[f(y,`u)`+` {Partial V} over {Partial y} g(y,`u)right}</SCRIPT></EQUATION><CHAR>, </CHAR><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1437072544" Lock="false" NumberingType="Equation" ZOrder="2611"><SIZE Height="1000" HeightRelTo="Absolute" Protect="false" Width="6275" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>V(T)`=`F(T)</SCRIPT></EQUATION><CHAR/></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>HJB 방정식은 또한 최적화의 충분조건도 된다.</CHAR><FOOTNOTE><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="11"><TEXT CharShape="11"><AUTONUM Number="84" NumberType="Footnote"><AUTONUMFORMAT SuffixChar=")" Superscript="false" Type="Digit"/></AUTONUM><CHAR> 자세한 증명은 </CHAR><FIELDBEGIN Command="http\://kurser.math.su.se/mod/resource/view.php\?id=38;1;0;0;" Dirty="true" Editable="false" InstId="1436464082" Property="0" Type="Hyperlink"/></TEXT><TEXT CharShape="4"><CHAR>http://kurser.math.su.se/mod/resource/view.php?id=38</CHAR></TEXT><TEXT CharShape="11"><FIELDEND Editable="false" Property="0" Type="Hyperlink"/><CHAR> </CHAR></TEXT></P><P ParaShape="1" Style="11"><TEXT CharShape="11"><CHAR>    “Dynamic Programming: Continuous-Time Case”, p.3. 참조.</CHAR></TEXT></P></PARALIST></FOOTNOTE><CHAR> 따라서 HJB 방정식은 최적화의 필요충분조건이다.</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>Bellman 방정식은 비선형의 1차 편미분방정식으로 대수적으로 해를 구할 수 있는 경우는 극히 제한적이다. 대부분의 문제는 수치해석의 기법을 적용하여 푼다.</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="1"><CHAR>LQ(linear quadratic) 문제</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>기간 [</CHAR><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1436464088" Lock="false" NumberingType="Equation" ZOrder="2545"><SIZE Height="1000" HeightRelTo="Absolute" Protect="false" Width="1470" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>0,` tau </SCRIPT></EQUATION><CHAR>] 동안 2차 형식으로 된 비용을 최소화하는 다음과 같은 형태의 문제를 LQ 문제, 또는 LQ 규제(LQ control)라 한다. </CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>min </CHAR><EQUATION BaseLine="62" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1436464076" Lock="false" NumberingType="Equation" ZOrder="2541"><SIZE Height="2586" HeightRelTo="Absolute" Protect="false" Width="1560" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>it  int _{0} ^{tau } {}</SCRIPT></EQUATION><CHAR>[</CHAR></TEXT><TEXT CharShape="20"><CHAR>x</CHAR></TEXT><TEXT CharShape="17"><CHAR>T</CHAR></TEXT><TEXT CharShape="8"><CHAR>(t)</CHAR></TEXT><TEXT CharShape="20"><CHAR>Qx</CHAR></TEXT><TEXT CharShape="8"><CHAR>(t)</CHAR></TEXT><TEXT CharShape="20"><CHAR> </CHAR></TEXT><TEXT CharShape="8"><CHAR>+ </CHAR></TEXT><TEXT CharShape="20"><CHAR>u</CHAR></TEXT><TEXT CharShape="17"><CHAR>T</CHAR></TEXT><TEXT CharShape="8"><CHAR>(t)</CHAR></TEXT><TEXT CharShape="20"><CHAR>Ru</CHAR></TEXT><TEXT CharShape="8"><CHAR>(t)]dt + </CHAR></TEXT><TEXT CharShape="20"><CHAR>x</CHAR></TEXT><TEXT CharShape="17"><CHAR>T</CHAR><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1436464083" Lock="false" NumberingType="Equation" ZOrder="2543"><SIZE Height="975" HeightRelTo="Absolute" Protect="false" Width="1270" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>( tau )</SCRIPT></EQUATION></TEXT><TEXT CharShape="20"><CHAR>Hx</CHAR><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1436464085" Lock="false" NumberingType="Equation" ZOrder="2544"><SIZE Height="975" HeightRelTo="Absolute" Protect="false" Width="1270" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>( tau )</SCRIPT></EQUATION></TEXT><TEXT CharShape="8"><CHAR/></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"><CHAR>s.t   </CHAR></TEXT><TEXT CharShape="20"><CHAR>x</CHAR><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1436464079" Lock="false" NumberingType="Equation" ZOrder="2542"><SIZE Height="975" HeightRelTo="Absolute" Protect="false" Width="300" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>'</SCRIPT></EQUATION></TEXT><TEXT CharShape="8"><CHAR>(t) = </CHAR></TEXT><TEXT CharShape="20"><CHAR>Ax</CHAR></TEXT><TEXT CharShape="8"><CHAR>(t)</CHAR></TEXT><TEXT CharShape="20"><CHAR> </CHAR></TEXT><TEXT CharShape="8"><CHAR>+ </CHAR></TEXT><TEXT CharShape="20"><CHAR>Bu</CHAR></TEXT><TEXT CharShape="8"><CHAR>(t)</CHAR></TEXT></P><P ParaShape="0" Style="0"><TEXT CharShape="8"/></P><P ParaShape="0" Style="0"><TEXT CharShape="20"><CHAR>x</CHAR></TEXT><TEXT Ch