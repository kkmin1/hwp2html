+ TRIANGLE t} {} f(y,`u)d tau </SCRIPT></EQUATION><CHAR> </CHAR><EQUATION BaseLine="72" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1403303628" Lock="false" NumberingType="Equation" ZOrder="1064"><SIZE Height="1192" HeightRelTo="Absolute" Protect="false" Width="10458" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>CONG `max  _{u(t)`} LEFT { f(y,`u) TRIANGLE t RIGHT }</SCRIPT></EQUATION><CHAR>.............</CHAR><FOOTNOTE><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="11"><TEXT CharShape="11"><AUTONUM Number="82" NumberType="Footnote"><AUTONUMFORMAT SuffixChar=")" Superscript="false" Type="Digit"/></AUTONUM><CHAR> 적분의 정의에 의해 </CHAR><EQUATION BaseLine="84" BaseUnit="800" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1432690178" Lock="false" NumberingType="Equation" ZOrder="2404"><SIZE Height="825" HeightRelTo="Absolute" Protect="false" Width="2175" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>TRIANGLE t -&gt; 0</SCRIPT></EQUATION><CHAR> 이면 </CHAR><EQUATION BaseLine="84" BaseUnit="800" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1432690179" Lock="false" NumberingType="Equation" ZOrder="2405"><SIZE Height="825" HeightRelTo="Absolute" Protect="false" Width="3443" WidthRelTo="A