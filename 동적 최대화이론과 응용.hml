"15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="72" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="2038222009" Lock="false" NumberingType="Equation" ZOrder="77"><SIZE Height="1177" HeightRelTo="Absolute" Protect="false" Width="7195" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>H  _{u} =f  _{u} + lambda =0</SCRIPT></EQUATION><CHAR> </CHAR></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><CHAR>양변을 t로 미분하면</CHAR></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="69" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="2038222029" Lock="false" NumberingType="Equation" ZOrder="87"><SIZE Height="2452" HeightRelTo="Absolute" Protect="false" Width="5710" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>{df  _{u}} over {dt} + lambda '=0</SCRIPT></EQUATION><CHAR/></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><CHAR>한편 </CHAR><EQUATION BaseLine="72" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="2038222011" Lock="false" NumberingType="Equation" ZOrder="78"><SIZE Height="1190" HeightRelTo="Absolute" Protect="false" Width="7170" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>H  _{y} `=`f  _{y} `=`- lambda  prime </SCRIPT></EQUATION><CHAR> 이므로 이를 위식에 대입하면</CHAR></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="69" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="2038222031" Lock="false" NumberingType="Equation" ZOrder="88"><SIZE Height="2452" HeightRelTo="Absolute" Protect="false" Width="4085" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>{df  _{u}} over {dt} =f  _{y}</SCRIPT></EQUATION><CHAR/></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="86" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="2038222032" Lock="false" NumberingType="Equation" ZOrder="89"><SIZE Height="975" HeightRelTo="Absolute" Protect="false" Width="2670" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>u=y'</SCRIPT></EQUATION><CHAR> 이므로</CHAR></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="69" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="2038222034" Lock="false" NumberingType="Equation" ZOrder="90"><SIZE Height="2452" HeightRelTo="Absolute" Protect="false" Width="4235" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>{df  _{y'}} over {dt} =f  _{y}</SCRIPT></EQUATION><CHAR> ; 오일러방정식</CHAR></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><CHAR>최종값이 정해지지 않은 경우라면</CHAR></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><CHAR>최적제어문제의 transversality 조건은 </CHAR><EQUATION BaseLine="72" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="2038222035" Lock="false" NumberingType="Equation" ZOrder="91"><SIZE Height="1177" HeightRelTo="Absolute" Protect="false" Width="4040" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT>수식입니다.</SHAPECOMMENT></SHAPEOBJECT><SCRIPT>lambda (t  _{1} )=0</SCRIPT></EQUATION><CHAR/></TEXT></P><P ParaShape="15" Style="0"><TEXT CharShape="8"/></P><P ParaShape="15" Style="0"><TEXT CharShape="8"><EQUATION BaseLine="72" BaseUnit="1000" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="